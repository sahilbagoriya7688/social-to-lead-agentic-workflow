# Copy this file to .env and fill in your values

# Google Gemini API Key (FREE - get it at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Model settings (gemini-1.5-flash is free and fast)
GEMINI_MODEL=gemini-1.5-flash

# Optional: Lead storage file path
LEADS_FILE=data/leads.json

# Optional: Logging level
LOG_LEVEL=INFO
